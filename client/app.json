{
  "expo": {
    "name": "Forever",
    "slug": "forever",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "forever",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amalrxj.forever",
      "buildNumber": "1"
    },

    "android": {
      "package": "com.amalrxj.forever",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/icon.png",
          "imageWidth": 100
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "@clerk/expo",
      "expo-secure-store",
      "expo-font"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    }
  }
}
